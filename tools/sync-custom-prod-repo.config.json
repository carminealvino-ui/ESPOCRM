{
    "scanRoots": [
        "custom/Espo/Custom",
        "client/custom",
        "custom/Espo/Modules/Sales/Resources",
        "custom/Espo/Modules/Sales/Hooks",
        "custom/Espo/Modules/Sales/Classes",
        "custom/Espo/Modules/Google/Hooks",
        "tools"
    ],
    "prodToRepoPathAliases": [
        {
            "prodPrefix": "custom/Espo/Custom/Resources/client/custom",
            "repoPrefix": "client/custom"
        },
        {
            "prodPrefix": "custom/Espo/Custom/client/custom",
            "repoPrefix": "client/custom"
        }
    ],
    "excludePatterns": [
        "*.bak",
        "*.bak-*",
        "*.save",
        "*_BACKUP*",
        "*~",
        ".DS_Store"
    ],
    "excludePathContains": [
        "/.git/",
        "/node_modules/",
        "/custom/Espo/Custom/client/custom-views/cache",
        "/Modules/Sales/vendor/",
        "/client/custom/modules/advanced/",
        "/client/custom/modules/google/",
        "/client/custom/modules/outlook/"
    ],
    "excludePathRegex": [
        "#/i18n/(?!it_IT/)#"
    ],
    "github": {
        "repository": "carminealvino-ui/ESPOCRM",
        "branch": "main"
    }
}
