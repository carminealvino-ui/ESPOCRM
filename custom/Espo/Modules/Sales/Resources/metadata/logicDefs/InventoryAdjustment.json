{
    "fields": {
        "isLocked": {
            "visible": {
                "conditionGroup": [
                    {
                        "type": "isTrue",
                        "attribute": "isNotActual"
                    }
                ]
            }
        },
        "status": {
            "readOnly": {
                "conditionGroup": [
                    {
                        "type": "isTrue",
                        "attribute": "isDone"
                    }
                ]
            }
        },
        "itemList": {
            "readOnly": {
                "conditionGroup": [
                    {
                        "type": "or",
                        "value": [
                            {
                                "type": "isTrue",
                                "attribute": "isDone"
                            }
                        ]
                    }
                ]
            }
        },
        "number": {
            "visible": {
                "conditionGroup": [
                    {
                        "type": "isNotEmpty",
                        "attribute": "id"
                    }
                ]
            }
        }
    }
}
