{
    "fields": {
        "name": {
            "type": "varchar",
            "requited": true,
            "maxLength": 150
        },
        "order": {
            "type": "int",
            "readOnly": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Active",
                "Inactive"
            ],
            "default": "Active",
            "style": {
                "Inactive": "info"
            },
            "maxLength": 8,
            "audited": true,
            "customizationDisabled": true
        },
        "items": {
            "type": "jsonArray",
            "view": "modules/sales/views/payment-terms-profile/fields/items",
            "notStorable": true,
            "massUpdateDisabled": true,
            "validatorClassNameList": [
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\PaymentTermsProfile\\Items\\Valid"
            ],
            "loaderClassName": "Espo\\Modules\\Sales\\Classes\\FieldLoaders\\PaymentTermsProfile\\Items",
            "required": true,
            "audited": true
        },
        "note": {
            "type": "text",
            "audited": true,
            "tooltip": true,
            "rowsMin": 1,
            "maxLength": 4000
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "items": {
            "type": "hasMany",
            "entity": "PaymentTermsProfileItem",
            "foreign": "profile",
            "readOnly": true,
            "orderBy": "order",
            "order": "asc"
        },
        "invoices": {
            "type": "hasMany",
            "entity": "Invoice",
            "readOnly": true,
            "foreign": "paymentTermsProfile"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "order",
        "order": "asc",
        "textFilterFields": [
            "name"
        ]
    }
}
