            "duplicateIgnore": true,
            "view": "modules/sales/views/quote/fields/is-locked"
        },
        "isDone": {
            "type": "bool",
            "readOnly": true,
            "fieldManagerParamList": [
                "audited",
                "tooltipText"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "isNotActual": {
            "type": "bool",
            "readOnly": true,
            "fieldManagerParamList": [
                "audited",
                "tooltipText"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "isIssued": {
            "type": "bool",
            "readOnly": true,
            "fieldManagerParamList": [
                "audited",
