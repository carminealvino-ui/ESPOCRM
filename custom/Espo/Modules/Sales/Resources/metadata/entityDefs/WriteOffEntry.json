        "wasIssued": {
            "type": "bool",
            "readOnly": true,
            "fieldManagerParamList": [
                "tooltipText"
            ],
            "directUpdateDisabled": true,
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "issuedBy": {
            "type": "link",
            "readOnly": true,
            "fieldManagerParamList": [
                "tooltipText"
            ],
            "duplicateIgnore": true
        },
        "issuedAt": {
