            "dynamicLogicDisabled": true,
            "directUpdateDisabled": true,
            "foreignAccessDisabled": true,
            "customizationReadOnlyDisabled": true,
            "conversionDisabled": true,
            "loaderClassName": "Espo\\Modules\\Sales\\Classes\\FieldLoaders\\WriteOffEntry\\UnallocatedAmount",
            "fieldManagerParamList": [],
            "duplicateIgnore": true,
            "filtersEnabled": true,
            "listColumnEnabled": true
        },
        "unallocatedAmountConverted": {
            "type": "currencyConverted",
            "readOnly": true,
            "customizationDisabled": true,
            "utility": true,
            "duplicateIgnore": true
        },
        "unallocatedAmountCurrency": {
            "type": "enum",
            "readOnly": true,
            "customizationDisabled": true,
            "utility": true
        },
        "amountCurrency": {
            "type": "enum",
            "customizationDisabled": true
        },
        "description": {
            "type": "text"
        },
        "allocations": {
            "type": "jsonArray",
            "view": "modules/sales/views/payment-entry/fields/allocations",
            "notStorable": true,
            "massUpdateDisabled": true,
            "forceValidation": true,
            "validatorClassNameList": [
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\CreditNote\\Allocations\\Valid",
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\CreditNote\\Allocations\\SameCurrencyAsAmount",
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\WriteOffEntry\\Allocations\\OnlyIfApplied"
            ],
            "loaderClassName": "Espo\\Modules\\Sales\\Classes\\FieldLoaders\\WriteOffEntry\\Allocations",
            "fieldManagerAdditionalParamList": [
                {
                    "name": "audited",
                    "type": "bool"
                }
            ],
            "audited": true,
            "duplicateIgnore": true
        },
        "teams": {
            "type": "linkMultiple",
            "audited": true
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
