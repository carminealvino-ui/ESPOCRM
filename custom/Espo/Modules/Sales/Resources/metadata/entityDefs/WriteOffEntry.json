    "links": {
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "writeOffEntries"
        },
        "allocations": {
            "type": "hasMany",
            "entity": "PaymentAllocation",
            "foreign": "writeOffEntry",
            "readOnly": true,
            "customizationDisabled": true,
            "layoutRelationshipsDisabled": true,
            "orderBy": "number",
            "order": "asc"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "issuedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "number"
        ]
    },
    "indexes": {
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        }
    },
    "optimisticConcurrencyControl": true
}
