            "type": "varchar",
            "utility": true,
            "select": {
                "select": "number"
            },
            "duplicateIgnore": true
        },
        "number": {
            "type": "varchar",
            "maxLength": 100,
            "index": true,
            "readOnly": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "useAutoincrement",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "useAutoincrement",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ],
            "dynamicLogicDisabled": true,
            "useAutoincrement": true,
            "duplicateIgnore": true
        },
        "numberA": {
            "type": "number",
            "prefix": "WO-",
            "padLength": 5,
            "layoutAvailabilityList": [],
            "textFilterDisabled": true,
            "directAccessDisabled": true,
            "fieldManagerParamList": [
                "prefix",
                "nextNumber",
                "padLength"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true,
            "suppressHook": true
        },
        "numberDraftA": {
            "type": "number",
            "prefix": "PRE-WO-",
            "padLength": 5,
            "layoutAvailabilityList": [],
