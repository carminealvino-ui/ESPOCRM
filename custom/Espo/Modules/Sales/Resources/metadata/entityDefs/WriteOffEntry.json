                "Applied": "success",
                "Canceled": "info"
            },
            "default": "Draft",
            "displayAsLabel": true,
            "labelType": "state",
            "index": true,
            "maxLength": 11,
            "fieldManagerParamList": [
                "default",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "inlineEditDisabled"
            ],
            "audited": true,
            "duplicateIgnore": true,
            "view": "modules/sales/views/general/fields/status"
        },
        "account": {
            "type": "link",
            "audited": true
        },
        "date": {
            "type": "date",
