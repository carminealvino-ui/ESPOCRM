{
    "fields": {
        "name": {
            "type": "varchar",
            "duplicateIgnore": true,
            "readOnly": true,
            "syncWithNumber": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "syncWithNumber",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "syncWithNumber",
                "options",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ]
        },
        "number": {
            "type": "varchar",
            "maxLength": 100,
            "index": true,
            "readOnly": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "useAutoincrement",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "useAutoincrement",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ],
            "dynamicLogicDisabled": true,
            "useAutoincrement": true,
            "duplicateIgnore": true
        },
        "numberA": {
            "type": "number",
            "prefix": "RO-",
            "padLength": 5,
            "layoutAvailabilityList": [],
            "textFilterDisabled": true,
            "directAccessDisabled": true,
            "fieldManagerParamList": [
                "prefix",
                "nextNumber",
                "padLength"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Draft",
                "Ready",
                "Completed",
                "Canceled"
            ],
            "style": {
                "Ready": "primary",
                "Completed": "success",
                "Canceled": "info"
            },
            "default": "Draft",
            "displayAsLabel": true,
            "labelType": "state",
            "fieldManagerAdditionalParamList": [
                {
                    "name": "notActualOptions",
                    "view": "sales:views/admin/field-manager/fields/not-actual-options"
                }
            ],
            "notActualOptions": ["Completed", "Canceled"],
            "index": true,
            "audited": true,
            "duplicateIgnore": true
        },
        "dateOrdered": {
            "type": "date",
            "default": "javascript: return this.dateTime.getToday();",
            "audited": true
        },
        "dateReceived": {
            "type": "date",
            "audited": true,
            "duplicateIgnore": true
        },
        "account": {
            "type": "link",
            "readOnly": true,
            "audited": true
        },
        "supplier": {
            "type": "link",
            "autocompleteOnEmpty": true,
            "audited": true
        },
        "purchaseOrder": {
            "type": "link",
            "view": "sales:views/receipt-order/fields/purchase-order",
            "audited": true
        },
        "returnOrder": {
            "type": "link",
            "view": "sales:views/receipt-order/fields/return-order",
            "audited": true
        },
        "warehouse": {
            "type": "link",
            "validatorClassNameList": [
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\DeliveryOrder\\Warehouse\\Required"
            ],
            "autocompleteOnEmpty": true
        },
        "description": {
            "type": "text"
        },
        "shippingContact": {
            "type": "link",
            "view": "sales:views/quote/fields/contact",
            "audited": true
        },
        "shippingProvider": {
            "type": "link",
            "autocompleteOnEmpty": true,
            "audited": true
        },
        "shippingCost": {
            "type": "currency",
            "layoutAvailabilityList": [
                "list",
                "filters"
            ],
            "audited": true
        },
        "amount": {
            "type": "currency",
            "notStorable": true,
            "readOnly": true,
            "utility": true,
            "directAccessDisabled": true,
            "dynamicLogicDisabled": true,
            "customizationDisabled": true,
            "audited": true,
            "fieldManagerParamList": [
                "audited"
            ]
        },
        "amountConverted": {
            "utility": true,
            "readOnly": true
        },
        "amountCurrency": {
            "utility": true
        },
        "weight": {
            "type": "float",
            "min": 0,
            "decimalPlaces": 2,
            "readOnly": true,
            "fieldManagerParamList": [
                "audited",
                "decimalPlaces",
                "tooltipText"
            ],
            "view": "modules/sales/views/fields/weight"
        },
        "shippingCostCurrency": {
            "customizationDisabled": true
        },
        "itemList": {
            "type": "jsonArray",
