    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "shippingProvider": {
            "type": "belongsTo",
            "entity": "ShippingProvider"
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "receiptOrders"
        },
        "supplier": {
            "type": "belongsTo",
            "entity": "Supplier"
        },
        "purchaseOrder": {
            "type": "belongsTo",
            "entity": "PurchaseOrder",
            "foreign": "receiptOrders"
        },
        "returnOrder": {
            "type": "belongsTo",
            "entity": "ReturnOrder",
            "foreign": "receiptOrders"
        },
        "shippingContact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "receiptOrdersShipping"
        },
        "warehouse": {
            "type": "belongsTo",
            "entity": "Warehouse"
        },
        "items": {
            "type": "hasMany",
            "entity": "ReceiptOrderItem",
            "foreign": "receiptOrder",
            "layoutRelationshipsDisabled": true,
            "readOnly": true
        },
        "receivedItems": {
            "type": "hasMany",
            "entity": "ReceiptOrderReceivedItem",
            "foreign": "receiptOrder",
            "layoutRelationshipsDisabled": true,
            "readOnly": true
        },
        "inventoryTransactions": {
            "type": "hasChildren",
            "entity": "InventoryTransaction",
            "foreign": "parent"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "EntityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["name", "number"]
    },
    "indexes": {
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        }
    },
    "optimisticConcurrencyControl": true
}
