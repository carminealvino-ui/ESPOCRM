            "default": "Active",
            "style": {
                "Inactive": "info"
            },
            "audited": true
        },
        "tax": {
            "type": "link",
            "readOnlyAfterCreate": true,
            "required": true
        },
        "class": {
            "type": "link",
            "required": true,
            "audited": true,
            "autocompleteOnEmpty": true
        },
        "basis": {
            "type": "foreign",
            "link": "tax",
            "field": "basis",
            "view": "views/fields/foreign-enum",
            "readOnly": true
        },
        "taxCode": {
            "type": "link",
            "audited": true,
            "autocompleteOnEmpty": true
        },
        "rate": {
            "type": "float",
            "min": 0,
            "max": 100,
            "decimalPlaces": 2,
            "audited": true,
            "view": "modules/sales/views/quote-item/fields/tax-rate"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "taxDisplay": {
            "type": "base",
            "notStorable": true,
            "readOnly": true,
            "directAccessDisabled": true,
            "directUpdateDisabled": true,
            "orderDisabled": true,
            "view": "modules/sales/views/tax/fields/tax-display"
        }
    },
    "links": {
        "tax": {
            "type": "belongsTo",
            "entity": "Tax"
        },
        "class": {
            "type": "belongsTo",
            "entity": "TaxClass"
        },
        "taxCode": {
            "type": "belongsTo",
            "entity": "TaxCode",
