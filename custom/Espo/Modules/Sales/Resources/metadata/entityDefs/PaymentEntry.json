            "directUpdateDisabled": true,
            "foreignAccessDisabled": true,
            "customizationReadOnlyDisabled": true,
            "conversionDisabled": true,
            "loaderClassName": "Espo\\Modules\\Sales\\Classes\\FieldLoaders\\PaymentEntry\\UnallocatedAmount",
