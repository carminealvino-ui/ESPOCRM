    "links": {
        "method": {
            "type": "belongsTo",
            "entity": "PaymentMethod",
            "foreign": "paymentEntries"
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "paymentEntries"
        },
        "supplier": {
