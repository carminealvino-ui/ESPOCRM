   <\/tr>\n    <tr iterate=\"{{itemList}}\">\n      <td>{{order}}<\/td>\n      <td>{{name}}<p x-if=\"{{description}}\" style=\"font-size: 0.8em\">{{{description}}}<\/p><\/td>\n      <td>{{quantity}}<\/td>\n    <\/tr>\n  <\/tbody>\n<\/table>\n",
