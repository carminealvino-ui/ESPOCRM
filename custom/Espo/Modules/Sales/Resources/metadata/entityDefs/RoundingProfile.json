{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 48,
            "required": true
        },
        "order": {
            "type": "int",
            "readOnly": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Active",
                "Inactive"
            ],
            "default": "Active",
            "style": {
                "Inactive": "info"
            },
            "maxLength": 8,
            "audited": true
        },
        "roundingFactor": {
            "type": "varchar",
            "dbType": "decimal",
            "required": true,
            "audited": true,
            "default": "1",
            "min": 0.01,
            "max": 1000,
            "precision": 13,
            "scale": 2,
            "decimalPlaces": 2,
            "validationList": [
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\General\\Decimal\\Valid",
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\General\\Decimal\\Range"
            ],
            "view": "modules/sales/views/fields/decimal",
            "tooltip": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "textFilterFields": [
            "name"
        ],
        "orderBy": "order",
        "order": "asc"
    },
    "indexes": {
        "orderStatus": {
            "columns": [
                "order",
                "status"
            ]
        }
    }
}
