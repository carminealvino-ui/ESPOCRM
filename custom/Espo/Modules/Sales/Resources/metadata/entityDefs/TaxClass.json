{
    "fields": {
        "name": {
            "type": "varchar",
            "maxLength": 50,
            "required": true,
            "audited": true,
            "index": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        }
    },
    "links": {
        "products": {
            "type": "hasMany",
            "entity": "Product",
            "foreign": "taxClasses",
            "readOnly": true
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "asc",
        "textFilterFields": [
            "name"
        ]
    }
}
