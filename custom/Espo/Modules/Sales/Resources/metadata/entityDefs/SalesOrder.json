            "type": "varchar",
            "duplicateIgnore": true,
            "readOnly": true,
            "syncWithNumber": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "syncWithNumber",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "syncWithNumber",
                "options",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ]
        },
        "number": {
            "type": "varchar",
            "maxLength": 100,
            "index": true,
            "readOnly": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "useAutoincrement",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "useAutoincrement",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ],
            "dynamicLogicDisabled": true,
            "useAutoincrement": true,
            "duplicateIgnore": true
        },
        "numberA": {
            "type": "number",
