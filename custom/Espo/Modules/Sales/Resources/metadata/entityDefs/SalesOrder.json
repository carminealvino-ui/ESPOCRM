            "type": "float",
            "min": 0,
            "max": 100,
            "readOnly": true,
            "customizationReadOnlyDisabled": true,
            "customizationReadOnlyAfterCreateDisabled": true
        },
        "taxCode": {
            "type": "link",
            "entity": "TaxCode",
            "readOnly": true,
            "notStorable": true,
            "utility": true,
            "loaderClassName": "Espo\\Modules\\Sales\\Classes\\FieldLoaders\\Quote\\TaxCodeLoader"
        },
        "taxTotals": {
            "type": "jsonArray",
            "notStorable": true,
            "readOnly": true,
