    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "tax": {
            "type": "belongsTo",
            "entity": "Tax"
        },
        "shippingProvider": {
            "type": "belongsTo",
            "entity": "ShippingProvider"
        },
        "account": {
            "type": "belongsTo",
            "entity": "Account",
            "foreign": "salesOrders"
        },
        "opportunity": {
            "type": "belongsTo",
            "entity": "Opportunity",
            "foreign": "salesOrders"
        },
        "quote": {
            "type": "belongsTo",
            "entity": "Quote",
            "foreign": "salesOrders"
        },
        "invoices": {
            "type": "hasMany",
            "entity": "Invoice",
            "foreign": "salesOrder",
            "audited": true,
            "readOnly": true
        },
        "deliveryOrders": {
            "type": "hasMany",
            "entity": "DeliveryOrder",
            "foreign": "salesOrder",
            "audited": true,
            "readOnly": true
        },
        "returnOrders": {
            "type": "hasMany",
            "entity": "ReturnOrder",
            "foreign": "salesOrder",
            "audited": true,
            "readOnly": true
        },
        "billingContact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "salesOrdersBilling"
        },
        "shippingContact": {
            "type": "belongsTo",
            "entity": "Contact",
            "foreign": "salesOrdersShipping"
        },
        "items": {
            "type": "hasMany",
            "entity": "SalesOrderItem",
            "foreign": "salesOrder",
            "layoutRelationshipsDisabled": true,
            "readOnly": true
        },
        "inventoryTransactions": {
            "type": "hasChildren",
            "entity": "InventoryTransaction",
            "foreign": "parent"
        },
        "priceBook": {
            "type": "belongsTo",
            "entity": "PriceBook"
        },
        "taxLineItems": {
            "type": "hasChildren",
            "entity": "TaxLineItem",
            "foreign": "source",
            "layoutRelationshipsDisabled": true,
            "readOnly": true,
            "orderBy": "order",
            "order": "asc"
        },
        "taxTotalItems": {
            "type": "hasChildren",
            "entity": "TaxTotalItem",
            "foreign": "source",
            "layoutRelationshipsDisabled": true,
            "readOnly": true,
            "orderBy": "order",
            "order": "asc"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "EntityTeam",
            "layoutRelationshipsDisabled": true
        }
