                "tooltipText"
            ],
            "readOnly": true,
            "view": "modules/sales/views/fields/weight"
        },
        "amountLocalCurrency": {
            "customizationDisabled": true
        },
        "taxAmountCurrency": {
            "customizationDisabled": true
        },
        "shippingCostCurrency": {
            "customizationDisabled": true
        },
