{
    "fields": {
        "name": {
            "type": "varchar",
            "duplicateIgnore": true,
            "readOnly": true,
            "syncWithNumber": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "syncWithNumber",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "syncWithNumber",
                "options",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ]
        },
        "number": {
            "type": "varchar",
            "maxLength": 100,
            "index": true,
            "readOnly": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "useAutoincrement",
                    "type": "bool"
                }
            ],
            "fieldManagerParamList": [
                "useAutoincrement",
                "required",
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "pattern",
                "copyToClipboard",
                "inlineEditDisabled"
            ],
            "dynamicLogicDisabled": true,
            "useAutoincrement": true,
            "duplicateIgnore": true
        },
        "numberA": {
            "type": "number",
            "prefix": "ADJ-",
            "padLength": 5,
            "layoutAvailabilityList": [],
            "textFilterDisabled": true,
            "directAccessDisabled": true,
            "fieldManagerParamList": [
                "prefix",
                "nextNumber",
                "padLength"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "status": {
            "type": "enum",
            "options": [
                "Draft",
                "Started",
                "Completed",
                "Canceled"
            ],
            "style": {
                "Started": "warning",
                "Completed": "success",
                "Canceled": "info"
            },
            "displayAsLabel": true,
            "labelType": "state",
            "default": "Draft",
            "index": true,
            "audited": true,
            "customizationOptionsReferenceDisabled": true,
            "customizationOptionsDisabled": true,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "notActualOptions",
                    "view": "sales:views/admin/field-manager/fields/not-actual-options"
                }
            ],
            "notActualOptions": ["Completed", "Canceled"],
            "duplicateIgnore": true
        },
        "reason": {
            "type": "enum",
            "options": [
                "",
                "Stocktaking",
                "Write-off",
                "Waste",
                "Shrinkage",
                "Damage",
                "Internal"
            ],
            "audited": true
        },
        "description": {
            "type": "text"
        },
        "warehouse": {
            "type": "link",
            "customizationRequiredDisabled": true,
            "readOnlyAfterCreate": true,
            "customizationReadOnlyAfterCreateDisabled": true,
            "validatorClassNameList": [
                "Espo\\Modules\\Sales\\Classes\\FieldValidators\\DeliveryOrder\\Warehouse\\Required"
            ],
            "autocompleteOnEmpty": true
        },
        "date": {
            "type": "date",
            "default": "javascript: return this.dateTime.getToday();",
            "audited": true,
            "required": true
        },
        "amount": {
            "type": "currency",
            "readOnly": true,
            "utility": true,
            "customizationDisabled": true
        },
        "amountConverted": {
            "utility": true,
            "readOnly": true
        },
        "amountCurrency": {
            "utility": true
        },
        "isLocked": {
            "type": "bool",
            "readOnly": true,
            "audited": true,
            "fieldManagerParamList": [
                "audited",
                "tooltipText"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true,
            "view": "modules/sales/views/quote/fields/is-locked"
        },
        "itemList": {
            "type": "jsonArray",
            "notStorable": true,
            "layoutAvailabilityList": [],
            "dynamicLogicVisibleDisabled": true,
            "dynamicLogicInvalidDisabled": true,
            "view": "sales:views/quote/fields/item-list",
            "templatePlaceholderDisabled": true,
            "reportDisabled": true,
            "workflowDisabled": true,
            "massUpdateDisabled": true,
            "duplicatorClassName": "Espo\\Modules\\Sales\\Classes\\FieldDuplicators\\Quote\\ItemList",
            "loaderClassName": "Espo\\Modules\\Sales\\Classes\\FieldLoaders\\Quote\\ItemListLoader",
            "isCompactForm": false,
            "fieldManagerAdditionalParamList": [
                {
                    "name": "isCompactForm",
                    "type": "bool"
                },
                {
                    "name": "audited",
                    "type": "bool"
                }
            ],
            "audited": true,
            "auditView": "modules/sales/views/quote/fields/audit-item-list"
        },
        "isDone": {
            "type": "bool",
            "readOnly": true,
            "fieldManagerParamList": [
                "audited",
                "tooltipText"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "isNotActual": {
            "type": "bool",
            "readOnly": true,
            "fieldManagerParamList": [
                "audited",
                "tooltipText"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "doneAt": {
            "type": "datetime",
            "readOnly": true,
            "fieldManagerParamList": [
                "tooltipText"
            ],
            "dynamicLogicDisabled": true,
            "duplicateIgnore": true
        },
        "products": {
            "type": "linkMultiple",
            "entity": "Product",
            "notStorable": true,
            "customizationDisabled": true,
            "directAccessDisabled": true,
            "fieldManagerParamList": [
                "prefix",
                "nextNumber",
                "padLength"
            ],
            "dynamicLogicDisabled": true,
            "layoutAvailabilityList": [
                "filters"
            ],
            "view": "sales:views/quote/fields/products"
        },
        "inventoryNumbers": {
            "type": "linkMultiple",
            "entity": "InventoryNumber",
            "notStorable": true,
            "customizationDisabled": true,
            "directAccessDisabled": true,
            "fieldManagerParamList": [
                "prefix",
                "nextNumber",
                "padLength"
            ],
            "dynamicLogicDisabled": true,
            "layoutAvailabilityList": [
                "filters"
            ],
            "view": "sales:views/quote/fields/inventory-numbers"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true
        },
        "assignedUser": {
            "type": "link",
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "warehouse": {
            "type": "belongsTo",
            "entity": "Warehouse"
        },
        "items": {
            "type": "hasMany",
            "entity": "InventoryAdjustmentItem",
            "foreign": "inventoryAdjustment",
            "layoutRelationshipsDisabled": true,
            "readOnly": true
        },
        "inventoryTransactions": {
            "type": "hasChildren",
            "entity": "InventoryTransaction",
            "foreign": "parent"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "EntityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["name", "number"]
    },
    "indexes": {
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        }
    },
    "optimisticConcurrencyControl": true
}
