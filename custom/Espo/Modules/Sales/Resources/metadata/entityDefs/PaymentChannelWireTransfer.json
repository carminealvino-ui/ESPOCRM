{
    "fields": {
        "accountHolder": {
            "type": "varchar",
            "maxLength": 255,
            "required": true
        },
        "iban": {
            "type": "varchar",
            "maxLength": 34,
            "pattern": "[A-Z]{2}[0-9]{2}[A-Z0-9]{11,30}"
        },
        "accountNumber": {
            "type": "varchar",
            "maxLength": 30,
            "pattern": "[A-Za-z0-9]{4,20}"
        },
        "bankName": {
            "type": "varchar",
            "maxLength": 30,
            "required": true
        },
        "bic": {
            "type": "varchar",
            "maxLength": 11,
            "pattern": "[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?"
        },
        "bankCode": {
            "type": "varchar",
            "maxLength": 32
        },
        "bankAddress": {
            "type": "address"
        }
    }
}
