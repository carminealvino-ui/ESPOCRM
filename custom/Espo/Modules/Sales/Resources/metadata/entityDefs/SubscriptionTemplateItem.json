            "fieldManagerParamList": [
                "tooltipText"
            ],
            "dynamicLogicDisabled": true
        },
        "fixedQuantity": {
            "type": "bool",
            "readOnly": true,
            "itemNotReadOnly": true,
            "fieldManagerParamList": [
                "tooltipText"
            ],
            "dynamicLogicDisabled": true
        },
        "order": {
            "type": "int",
