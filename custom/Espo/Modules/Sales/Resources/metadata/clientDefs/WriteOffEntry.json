            "modules/sales/handlers/general/issuance-locking-setup-record-detail"
        ],
        "record/edit": [
            "modules/sales/handlers/write-off-entry/setup-record-detail",
            "modules/sales/handlers/general/issuance-locking-setup-record-detail"
        ]
    },
    "massActionDefs": {
        "lock": {
            "aclScope": "WriteOffEntry",
            "acl": "edit",
            "handler": "modules/sales/handlers/quote/lock-mass-action",
            "actionFunction": "actionLock",
            "initFunction": "initLock"
        },
        "unlock": {
            "aclScope": "WriteOffEntry",
            "acl": "edit",
            "handler": "modules/sales/handlers/quote/lock-mass-action",
            "actionFunction": "actionUnlock",
