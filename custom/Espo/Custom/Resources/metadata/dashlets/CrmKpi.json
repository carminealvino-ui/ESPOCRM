{
    "view": "custom:views/dashlets/crm-kpi",
    "aclScope": "Appuntamento",
    "options": {
        "fields": {
            "title": {
                "type": "varchar",
                "required": true
            },
            "period": {
                "type": "enum",
                "options": ["currentMonth", "previousMonth"]
            },
            "autorefreshInterval": {
                "type": "enumFloat",
                "options": [0, 0.5, 1, 2, 5, 10]
            }
        },
        "defaults": {
            "title": "KPI CRM",
            "period": "currentMonth",
            "autorefreshInterval": 5
        },
        "layout": [
            {
                "rows": [
                    [
                        {"name": "title"},
                        {"name": "period"}
                    ],
                    [
                        {"name": "autorefreshInterval"},
                        false
                    ]
                ]
            }
        ]
    },
    "accessDataList": [
        {
            "inPortalDisabled": true
        }
    ]
}
