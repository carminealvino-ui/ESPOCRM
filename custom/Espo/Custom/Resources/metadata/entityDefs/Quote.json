    "links": {
        "cAP": {
            "type": "belongsTo",
            "foreign": "quote",
            "entity": "CAP",
            "audited": false,
            "isCustom": true
        },
        "prodotti": {
            "type": "hasMany",
            "relationName": "prodotticontratti",
            "foreign": "contratti",
            "entity": "Product",
            "audited": false,
            "isCustom": true
        },
        "provvigioni": {
            "type": "hasMany",
            "foreign": "contratto",
            "entity": "Provvigione",
            "audited": false,
            "isCustom": true
        },
        "fornitorePartner": {
            "type": "belongsTo",
            "entity": "FornitorePartner",
            "foreign": "quotes",
            "isCustom": true
        },
        "productBrand": {
            "type": "belongsTo",
            "entity": "ProductBrand",
            "foreign": "quotes",
            "isCustom": true
        },
        "productCategory": {
            "type": "belongsTo",
            "entity": "ProductCategory",
            "foreign": "quotes",
            "isCustom": true
        },
        "itemList": {
            "view": "custom:views/quote/fields/item-list"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name",
            "number"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "optimisticConcurrencyControl": true
