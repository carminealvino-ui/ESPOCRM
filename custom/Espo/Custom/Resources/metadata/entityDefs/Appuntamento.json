{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "trim": true,
            "options": []
        },
        "status": {
            "type": "enum",
            "options": [
                "Planned",
                "Held",
                "Not Held",
                "Ingestibile"
            ],
            "default": "Planned",
            "style": {
                "Planned": "info",
                "Held": "success",
                "Not Held": "danger",
                "Ingestibile": "warning"
            },
            "audited": true
        },
        "dateStart": {
            "type": "datetimeOptional",
            "notNull": false,
            "required": true,
            "default": "javascript: return this.dateTime.getNow(15);",
            "audited": true,
            "useNumericFormat": true,
            "minuteStep": 30
        },
        "dateEnd": {
            "type": "datetimeOptional",
            "notNull": false,
            "required": true,
            "after": "dateStart",
            "useNumericFormat": true,
            "minuteStep": 30,
            "suppressValidationList": [
                "required"
            ]
        },
        "isAllDay": {
            "type": "bool",
            "readOnly": false,
            "layoutListDisabled": true,
            "layoutDetailDisabled": true,
            "layoutMassUpdateDisabled": true
        },
        "duration": {
            "type": "duration",
            "start": "dateStart",
            "end": "dateEnd",
            "options": [
                300,
                600,
                900,
                1800,
                2700,
                3600,
                5400,
                7200
            ],
            "default": 5400,
            "notStorable": true,
            "select": {
                "select": "TIMESTAMPDIFF_SECOND:(dateStart, dateEnd)"
            },
            "order": {
                "order": [
                    [
                        "TIMESTAMPDIFF_SECOND:(dateStart, dateEnd)",
                        "{direction}"
                    ]
                ]
            }
        },
        "parent": {
            "type": "linkParent",
            "entityList": [
                "Prospect",
                "Lead",
                "Account",
                "Contact",
                "FornitorePartner",
                "Provvigione"
            ]
        },
        "description": {
            "type": "text"
        },
        "reminders": {
            "type": "jsonArray",
            "notStorable": true,
            "layoutListDisabled": true
        },
        "createdAt": {
            "notNull": false,
            "type": "datetime",
            "readOnly": true,
            "useNumericFormat": true,
            "minuteStep": 30
        },
        "modifiedAt": {
            "notNull": false,
