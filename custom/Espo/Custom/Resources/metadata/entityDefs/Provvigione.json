{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "tipo": {
            "type": "enum",
            "options": [
                "Provvigione Base",
                "Referenza Personale",
                "Bonus (Sabato-Domenica)",
                "Plus Provvigionale",
                "Minus Provvigionale",
                "Gara (Soglia >2.5k)",
                "Gara (Soglia >3.5)",
                "Gara (Soglia >5k)"
            ],
            "style": {
                "Provvigione Base": null,
                "Referenza Personale": null,
                "Bonus (Sabato-Domenica)": null,
                "Plus Provvigionale": null,
                "Minus Provvigionale": null,
                "Gara (Soglia >2.5k)": null,
                "Gara (Soglia >3.5)": null,
                "Gara (Soglia >5k)": null
            ],
            "default": "Provvigione Base",
            "maxLength": 100,
            "isCustom": true
        },
        "cliente": {
            "type": "link"
        },
        "contratto": {
            "type": "link"
        },
        "importo": {
            "type": "currency",
            "isCustom": true
        },
        "tassoProvvigioni": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "contrattoArticoli": {
            "type": "link"
        },
        "hookVersion": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "meetings": {
            "type": "hasMany",
            "entity": "Meeting",
            "foreign": "parent"
        },
        "calls": {
            "type": "hasMany",
            "entity": "Call",
            "foreign": "parent"
        },
        "tasks": {
            "type": "hasChildren",
            "entity": "Task",
            "foreign": "parent"
        },
        "emails": {
            "type": "hasChildren",
            "entity": "Email",
            "foreign": "parent",
            "layoutRelationshipsDisabled": true
        },
        "cliente": {
            "type": "belongsTo",
            "foreign": "provvigioni",
            "entity": "Account",
            "audited": false,
            "isCustom": true
        },
        "contratto": {
            "type": "belongsTo",
            "foreign": "provvigioni",
            "entity": "Quote",
            "audited": false,
            "isCustom": true
        },
        "contrattoArticoli": {
            "type": "belongsTo",
            "foreign": "provvigioni",
            "entity": "QuoteItem",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}