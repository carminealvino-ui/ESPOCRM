{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "trim": true,
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": true,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "opportunita": {
            "type": "link"
        },
        "dataPagamento": {
            "notNull": false,
            "type": "date",
            "useNumericFormat": true,
            "isCustom": true
        },
        "importo": {
            "type": "currency",
            "onlyDefaultCurrency": true,
            "isCustom": true
        },
        "cliente": {
            "type": "link"
        },
        "lead": {
            "type": "link"
        },
        "dataFattura": {
            "notNull": false,
            "type": "date",
            "useNumericFormat": true,
            "isCustom": true
        },
        "invitoAFatturare": {
            "type": "link",
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "EntityTeam",
            "layoutRelationshipsDisabled": true
        },
        "opportunita": {
            "type": "belongsTo",
            "foreign": "pagamentiProvvigionali",
            "entity": "Opportunity",
            "audited": false,
            "isCustom": true
        },
        "cliente": {
            "type": "belongsTo",
            "foreign": "pagamentiProvvigionali",
            "entity": "Account",
            "audited": false,
            "isCustom": true
        },
        "lead": {
            "type": "belongsTo",
            "foreign": "pagamentiProvvigionali",
            "entity": "Lead",
            "audited": false,
            "isCustom": true
        },
        "invitoAFatturare": {
            "type": "belongsTo",
            "foreign": "pagamentoProvvigionale",
            "entity": "InvitoAFatturare",
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "name",
        "order": "desc",
        "textFilterFields": [
            "name",
            "opportunita.name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}
