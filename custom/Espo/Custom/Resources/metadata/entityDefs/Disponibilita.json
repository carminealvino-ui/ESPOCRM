{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "trim": true,
            "options": []
        },
        "status": {
            "type": "enum",
            "options": [
                "Presente",
                "Ferie",
                "Malattia",
                "Auto",
                "Indisponibile"
            ],
            "default": "Presente",
            "style": {
                "Presente": null,
                "Ferie": null,
                "Malattia": null,
                "Auto": null,
                "Indisponibile": null
            },
            "audited": false
        },
        "dateStart": {
            "type": "datetimeOptional",
            "notNull": false,
            "view": "crm:views/meeting/fields/date-start",
            "required": true,
            "default": "javascript: return this.dateTime.getNow(15);",
            "audited": true,
            "useNumericFormat": true,
            "minuteStep": 30
        },
        "dateEnd": {
            "type": "datetimeOptional",
            "notNull": false,
            "view": "crm:views/meeting/fields/date-end",
            "required": true,
            "after": "dateStart",
            "useNumericFormat": true,
            "minuteStep": 30,
            "suppressValidationList": [
                "required"
            ]
        },
        "isAllDay": {
            "type": "bool",
            "readOnly": false,
            "layoutListDisabled": true,
            "layoutDetailDisabled": true,
            "layoutMassUpdateDisabled": true
        },
        "duration": {
            "type": "duration",
            "start": "dateStart",
            "end": "dateEnd",
            "options": [
                300,
                600,
                900,
                1800,
                2700,
                3600,
                7200
            ],
            "default": 300,
            "notStorable": true,
            "select": {
                "select": "TIMESTAMPDIFF_SECOND:(dateStart, dateEnd)"
            },
            "order": {
                "order": [
                    [
                        "TIMESTAMPDIFF_SECOND:(dateStart, dateEnd)",
                        "{direction}"
                    ]
                ]
            }
        },
        "parent": {
            "type": "linkParent",
            "entityList": [
                "Account",
                "Lead",
                "Contact",
                "FornitorePartner",
                "Provvigione"
            ]
        },
        "description": {
            "type": "text"
        },
        "reminders": {
            "type": "jsonArray",
            "notStorable": true,
            "view": "crm:views/meeting/fields/reminders",
            "layoutListDisabled": true
        },
        "createdAt": {
            "notNull": false,
            "type": "datetime",
            "readOnly": true,
            "useNumericFormat": true,
            "minuteStep": 30
        },
        "modifiedAt": {
            "notNull": false,
            "type": "datetime",
            "readOnly": true,
            "useNumericFormat": true,
            "minuteStep": 30
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user",
            "disabled": true
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "azienda": {
            "type": "enum",
            "options": [
                "",
                "ARQUATI",
                "ARIEL",
                "PROGETTO"
            ],
            "style": {
                "": null,
                "ARQUATI": null,
                "ARIEL": null,
                "PROGETTO": null
            },
            "default": null,
            "isCustom": true
        },
        "dateStartDate": {
            "useNumericFormat": true
        },
        "dateEndDate": {
            "useNumericFormat": true
        },
        "area": {
            "type": "multiEnum",
            "storeArrayValues": true,
            "options": [
                "ROMA SUD",
                "ROMA EST",
                "ROMA NORD",
                "PESCARA",
                "CHIETI",
                "LATINA",
                "FROSINONE"
            ],
            "style": {
                "ROMA SUD": null,
                "ROMA EST": null,
                "ROMA NORD": null,
                "PESCARA": null,
                "CHIETI": null,
                "LATINA": null,
                "FROSINONE": null
            },
            "isCustom": true
        },
        "datadisponibilita": {
            "notNull": false,
            "type": "date",
            "useNumericFormat": true,
            "default": "javascript: return this.dateTime.getToday();",
            "isCustom": true
        },
        "color": {
            "type": "varchar",
            "trim": true,
            "options": [],
            "isCustom": true
        },
        "orarioInizio": {
            "notNull": false,
            "type": "datetime",
            "useNumericFormat": true,
            "minuteStep": 30,
            "isCustom": true,
            "after": "dateStart"
        },
        "orarioFine": {
            "notNull": false,
            "type": "datetime",
            "useNumericFormat": true,
            "minuteStep": 30,
            "isCustom": true,
            "after": "dateStart"
        },
        "assignedUsers": {
            "type": "linkMultiple",
            "view": "views/fields/assigned-users",
            "maxCount": 10
        },
        "collaborators": {
            "type": "linkMultiple",
            "view": "views/fields/collaborators",
            "maxCount": 30,
            "fieldManagerParamList": [
                "readOnly",
                "readOnlyAfterCreate",
                "audited",
                "autocompleteOnEmpty",
                "maxCount",
                "inlineEditDisabled",
                "tooltipText"
            ]
        },
        "productBrand": {
            "type": "link",
            "isCustom": true
        }
    },
    "links": {
        "parent": {
            "type": "belongsToParent",
            "foreign": "disponibilitaChildren"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User",
            "disabled": true
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "EntityTeam",
            "layoutRelationshipsDisabled": true
        },
        "assignedUsers": {
            "type": "hasMany",
            "entity": "User",
            "relationName": "entityUser",
            "layoutRelationshipsDisabled": true
        },
        "collaborators": {
            "type": "hasMany",
            "entity": "User",
            "relationName": "entityCollaborator",
            "layoutRelationshipsDisabled": true
        },
        "fornitorePartner": {
            "type": "hasMany",
            "foreign": "disponibilita",
            "entity": "FornitorePartner",
            "audited": false,
            "isCustom": true
        },
        "productBrand": {
            "type": "belongsTo",
            "foreign": "disponibilita",
            "entity": "ProductBrand",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "dateStart",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "dateStartStatus": {
            "columns": [
                "dateStart",
                "status"
            ]
        },
        "dateStart": {
            "columns": [
                "dateStart",
                "deleted"
            ]
        },
        "status": {
            "columns": [
                "status",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "assignedUserStatus": {
            "columns": [
                "assignedUserId",
                "status"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}